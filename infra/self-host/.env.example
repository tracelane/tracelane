# Tracelane self-host environment configuration
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Generate with: openssl rand -base64 32
# This is the auth secret. In single-tenant self-host mode it is ALSO the client
# bearer token — agents call the gateway with:
#   Authorization: Bearer <TRACELANE_MASTER_KEY>
TRACELANE_MASTER_KEY=

# Set at least one provider key
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Single-tenant self-host tenant id (ADR-067). Every span is stamped with this
# one UUID and every request authenticates as it. The default is fine for a
# single-node install; change it only if you want a specific workspace id.
# (TRACELANE_SELF_HOST=1 is set in docker-compose.yml; do not enable it in a
#  hosted/multi-tenant deployment — the binaries refuse to start if they detect
#  Postgres / WorkOS / a SPIRE socket.)
TRACELANE_SINGLE_TENANT_ID=00000000-0000-0000-0000-000000000001

# Logging level: error | warn | info | debug | trace
LOG_LEVEL=info

# ClickHouse password (auto-generated default is fine for single-node)
CLICKHOUSE_PASSWORD=tracelane_selfhost

# Rekor signing key for tamper-evident audit log anchoring.
# Generate: openssl genpkey -algorithm ed25519 -outform DER | base64 -w0
# Leave empty to disable Rekor anchoring (local hash chain still active).
TRACELANE_REKOR_SIGNING_KEY=

# Forward OTLP spans to an external collector (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://your-collector:4318
