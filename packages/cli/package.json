{
 "name": "@tracelanedev/cli",
 "version": "0.2.0",
 "description": "Tracelane CLI — tlane command-line tool",
 "repository": {
 "type": "git",
 "url": "git+https://github.com/tracelane/tracelane.git",
 "directory": "packages/cli"
 },
 "homepage": "https://tracelane.dev",
 "bugs": "https://github.com/tracelane/tracelane/issues",
 "bin": {
 "tlane": "./dist/index.js"
 },
 "main": "./dist/index.js",
 "scripts": {
 "build": "tsup src/index.ts --format cjs --dts --no-splitting",
 "dev": "tsup src/index.ts --format cjs --watch",
 "lint": "biome check src/",
 "typecheck": "tsc --noEmit",
 "pretest": "pnpm --filter @tracelanedev/audit-verifier build",
 "test": "vitest run --passWithNoTests"
 },
 "dependencies": {
 "@tracelanedev/audit-verifier": "workspace:*",
 "commander": "^12.0.0",
 "chalk": "^5.0.0",
 "fflate": "^0.8.0",
 "ora": "^8.0.0"
 },
 "devDependencies": {
 "@biomejs/biome": "^1.9.0",
 "@types/node": "^22.0.0",
 "tsup": "^8.0.0",
 "tsx": "^4.0.0",
 "typescript": "^5.5.0",
 "vitest": "^2.0.0"
 },
 "files": ["dist"],
 "license": "Apache-2.0",
 "publishConfig": {
 "access": "public",
 "registry": "https://registry.npmjs.org/"
 },
 "keywords": ["tracelane", "cli", "tlane", "ai-observability", "llm-tracing"]
}
