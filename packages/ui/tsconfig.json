{
 "compilerOptions": {
 "target": "ES2022",
 "lib": ["ES2022", "DOM", "DOM.Iterable"],
 "module": "ESNext",
 "moduleResolution": "Bundler",
 "jsx": "react-jsx",
 "strict": true,
 "noUncheckedIndexedAccess": true,
 "noEmit": true,
 "esModuleInterop": true,
 "skipLibCheck": true,
 "verbatimModuleSyntax": true,
 "types": ["react"]
 },
 "include": ["src/**/*.ts", "src/**/*.tsx"],
 "exclude": ["node_modules"]
}
