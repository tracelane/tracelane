{
	"name": "@tracelanedev/web",
	"version": "0.1.0",
	"private": true,
	"description": "Tracelane dashboard — Next.js 15 App Router",
	"scripts": {
		"dev": "next dev --turbopack",
		"prebuild": "pnpm --filter @tracelanedev/audit-verifier build",
		"build": "next build && node scripts/check-css-built.mjs",
		"start": "next start",
		"cf:build": "pnpm --filter @tracelanedev/audit-verifier build && opennextjs-cloudflare build",
		"cf:preview": "opennextjs-cloudflare preview",
		"cf:deploy": "opennextjs-cloudflare deploy",
		"lint": "biome check app/ components/ lib/",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:hero": "E2E_BYPASS_AUTH=1 E2E_LIGHT=1 playwright test audit-hero --project=chromium",
		"test:e2e:gate": "E2E_BYPASS_AUTH=1 E2E_LIGHT=1 playwright test dead-buttons global-chrome --project=chromium",
		"db:seed": "node db/seed.mjs"
	},
	"dependencies": {
		"@neondatabase/serverless": "^0.10.0",
		"@tanstack/react-query": "^5.62.0",
		"@tracelanedev/audit-verifier": "workspace:*",
		"@tracelanedev/ui": "workspace:*",
		"@workos-inc/authkit-nextjs": "^4.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.0.0",
		"drizzle-orm": "^0.45.2",
		"hash-wasm": "4.12.0",
		"motion": "^11.0.0",
		"next": "15.5.18",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"tailwind-merge": "^2.0.0",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@electric-sql/pglite": "^0.5.4",
		"@playwright/test": "^1.49.1",
		"@opennextjs/cloudflare": "1.19.11",
		"@tailwindcss/postcss": "^4.0.0",
		"@types/node": "^22.0.0",
		"@types/react": "19.0.0",
		"@types/react-dom": "19.0.0",
		"@vitejs/plugin-react": "^4.0.0",
		"babel-plugin-react-compiler": "1.0.0",
		"drizzle-kit": "^0.30.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.5.0",
		"vitest": "^2.0.0",
		"wrangler": "4.104.0"
	},
	"license": "Apache-2.0"
}
