# Tracelane dashboard — environment variables
# Copy to .env.local and fill in values before running.

# ── WorkOS (auth) ─────────────────────────────────────────────────────────────
# Get these from your WorkOS dashboard: https://dashboard.workos.com
WORKOS_CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxx
WORKOS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxx
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
# 32+ byte random secret: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ClickHouse ────────────────────────────────────────────────────────────────
# Dev: docker compose -f infra/dev/docker-compose.yml up -d
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=tracelane

# ── Tracelane gateway ─────────────────────────────────────────────────────────
# Shown in the traces page header. Point agents here.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080

# ── Neon Postgres (tenant/billing metadata) ───────────────────────────────────
DATABASE_URL=postgres://user:password@ep-xxx.us-east-1.aws.neon.tech/tracelane

# ── Billing — Polar.sh ────────────────────────────────────────────────────────
# The dashboard NEVER holds a Polar access token. All Polar API calls
# proxy through the Rust gateway, which owns POLAR_ACCESS_TOKEN +
# POLAR_WEBHOOK_SECRET (see top-level .env.example). The dashboard only
# needs to know where the gateway lives (NEXT_PUBLIC_GATEWAY_URL above)
# and where to redirect the user after the Polar-hosted portal closes.
TRACELANE_BILLING_RETURN_URL=https://app.tracelane.dev/settings/billing
